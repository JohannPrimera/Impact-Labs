# Gemini (existing)
GEMINI_API_KEY=

# Stripe — https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) while developing
STRIPE_SECRET_KEY=sk_test_...

# Public URL of the Vite app (used for Stripe redirects and product images)
CLIENT_URL=http://localhost:3000

# API port (default 4242)
PORT=4242

# Production (Vercel): your public site URL — Stripe redirects and product images
# If omitted on Vercel, VERCEL_URL is used automatically for preview deploys
# CLIENT_URL=https://your-site.vercel.app

# Only if the payment API is on a different host than the static site (not needed on Vercel)
# VITE_API_URL=https://your-api.example.com
